node_modules/
.DS_Store
*.log
.env
.env.*
# archkit dogfoods its own .arch/ — it is version-controlled (see ADR).
# Only the transient per-session review cache stays ignored.
.arch/.last-review.json
.archkit-progress.json
.archkit-config.json
.arch/goals/.loop-state.json
# Per-batch shared queue branch state (cgr-relay-queue-vs-project-routing):
# records the current ungrouped queue's cgr-queue-<date> branch name. Transient,
# local to the working batch — never committed.
.arch/goals/.queue-state.json
# Shared agent coordination board (cgr-agent-chat-coordination-board): a chat.md
# committed per feature branch is invisible across branches, so it stays SHARED
# and gitignored — never commits into a feature branch.
.arch/goals/chat.md
# CGR 2.0 persistent board (board-state-manager, ADR 0014): the append-only event
# log is SHARED, non-branch-isolated runtime state (like chat.md) — a board
# committed per feature branch is invisible across branches, defeating the whole
# point of a derived cross-lane view. Stays local; the board is purely derived.
.arch/board/

# .claude/settings.json is committed: archkit emits portable hook commands
# (node $CLAUDE_PROJECT_DIR/bin/*.mjs) so the guardrail config is shareable.
# Only the per-machine local override stays ignored.
.claude/settings.local.json

# Ephemeral agent worktrees (created by the harness for lane isolation).
.claude/worktrees/
